{
	"name": "portifolio-server",
	"version": "1.0.0",
	"description": "Backend server for my portifolio",
	"main": "dist/server.js",
	"engines": {
		"node": "22.x"
	},
	"scripts": {
		"dev": "tsx --env-file=.env watch src/server.ts",
		"build": "npx prisma generate && tsc",
		"start": "node --env-file=.env dist/server.js",
		"db:migrate": "npx prisma migrate deploy",
		"test:unit": "vitest"
	},
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jpedroccruz/portifolio-server.git"
	},
	"author": "jpedroccruz",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/jpedroccruz/portifolio-server/issues"
	},
	"homepage": "https://github.com/jpedroccruz/portifolio-server#readme",
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/node": "25.9.3",
		"biome": "0.2.2",
		"pino-pretty": "13.1.3",
		"prisma": "6.19.3",
		"tsx": "4.22.4",
		"typescript": "6.0.3",
		"vitest": "4.1.10"
	},
	"dependencies": {
		"@fastify/cors": "11.2.0",
		"@fastify/jwt": "10.1.0",
		"@prisma/client": "6.19.3",
		"fastify": "5.8.5",
		"fastify-type-provider-zod": "6.1.0",
		"postgres": "3.4.9",
		"zod": "4.4.3"
	}
}
